[global]
    monitor = 0
    follow = mouse
    width = (0, 400)
    height = 300
    origin = top-right
    offset = (0, -5)
    history_length = 20
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 450

    padding = 15
    horizontal_padding = 15
    frame_width = 2
    frame_color = "{color1}"
    separator_color = frame

    font = Satoshi Variable 11
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = center
    vertical_alignment = center

    icon_position = left
    max_icon_size = 64

    mouse_left_click = do_action, close_current
    mouse_middle_click = close_all
    mouse_right_click = close_current

    sticky_history = yes
    history_length = 20
    show_indicators = yes

    transparency = 0
    corner_radius = 10


[urgency_low]
    background = "{background}33"
    foreground = "{foreground}"
    frame_color = "{color1}"
    timeout = 3


[urgency_normal]
    background = "{background}44"
    foreground = "{foreground}"
    frame_color = "{color1}"
    timeout = 10


[urgency_critical]
    background = "{color1}cc"
    foreground = "{background}"
    frame_color = "{color1}"
    timeout = 30

